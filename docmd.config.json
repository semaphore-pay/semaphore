{
  "title": "Semaphore Pay",
  "url": "https://docs.semaphorepay.tech",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "logo": {
    "light": "assets/images/logo.svg",
    "dark": "assets/images/logo.svg",
    "href": "/",
    "alt": "Semaphore Pay",
    "height": "32px"
  },
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 Semaphore Pay.",
      "branding": false
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true,
    "customCss": [
      "/assets/css/branding.css"
    ]
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Introduction", "path": "/", "icon": "home" },
    {
      "title": "Quick Start",
      "icon": "rocket",
      "children": [
        { "title": "Overview", "path": "/quickstart" },
        { "title": "Install SDK", "path": "/quickstart/install" },
        { "title": "First API Call", "path": "/quickstart/first-call" }
      ]
    },
    {
      "title": "Core Concepts",
      "icon": "layers",
      "children": [
        { "title": "Collections", "path": "/concepts/collections" },
        { "title": "Subscriptions", "path": "/concepts/subscriptions" },
        { "title": "Products & Plans", "path": "/concepts/products-plans" },
        { "title": "Entitlements", "path": "/concepts/entitlements" }
      ]
    },
    {
      "title": "API Reference",
      "icon": "code",
      "children": [
        { "title": "Overview", "path": "/api-reference" },
        { "title": "Collections", "path": "/api-reference/collections" },
        { "title": "Plans", "path": "/api-reference/plans" },
        { "title": "Products", "path": "/api-reference/products" },
        { "title": "Customers", "path": "/api-reference/customers" },
        { "title": "Subscriptions", "path": "/api-reference/subscriptions" },
        { "title": "Entitlements", "path": "/api-reference/entitlements" }
      ]
    },
    {
      "title": "Guides",
      "icon": "book",
      "children": [
        { "title": "Webhooks", "path": "/guides/webhooks" },
        { "title": "Testing", "path": "/guides/testing" },
        { "title": "React Integration", "path": "/guides/react" },
        { "title": "React Native", "path": "/guides/react-native" }
      ]
    },
    {
      "title": "Deploy",
      "icon": "cloud",
      "children": [
        { "title": "Cloudflare", "path": "/deploy/cloudflare" },
        { "title": "Environment Variables", "path": "/deploy/env" }
      ]
    }
  ],
  "plugins": {
    "seo": {
      "defaultDescription": "Subscription billing engine for Nomba."
    },
    "llms": {}
  }
}
