{
  "name": "@semaphore-pay/server",
  "version": "0.1.28",
  "license": "MIT",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/api.service.d.ts",
      "import": "./dist/api/api.service.js"
    },
    "./plan": {
      "types": "./dist/plan/plan.api.d.ts",
      "import": "./dist/plan/plan.api.js"
    },
    "./product": {
      "types": "./dist/product/product.service.d.ts",
      "import": "./dist/product/product.service.js"
    },
    "./customer": {
      "types": "./dist/customer/customer.api.d.ts",
      "import": "./dist/customer/customer.api.js"
    },
    "./subscription": {
      "types": "./dist/subscription/subscription.api.d.ts",
      "import": "./dist/subscription/subscription.api.js"
    },
    "./feature": {
      "types": "./dist/feature/feature.api.d.ts",
      "import": "./dist/feature/feature.api.js"
    },
    "./entitlement": {
      "types": "./dist/entitlement/entitlement.api.d.ts",
      "import": "./dist/entitlement/entitlement.api.js"
    },
    "./webhook": {
      "types": "./dist/webhook/webhook.api.d.ts",
      "import": "./dist/webhook/webhook.api.js"
    },
    "./nomba": {
      "types": "./dist/nomba/nomba.d.ts",
      "import": "./dist/nomba/nomba.js"
    },
    "./schema/sqlite": {
      "types": "./dist/database/schema/sqlite.d.ts",
      "import": "./dist/database/schema/sqlite.js"
    },
    "./schema/pg": {
      "types": "./dist/database/schema/pg.d.ts",
      "import": "./dist/database/schema/pg.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "generate:pg": "DB_DIALECT=postgresql drizzle-kit generate",
    "generate:sqlite": "DB_DIALECT=sqlite drizzle-kit generate",
    "generate:all": "bun run generate:pg && bun run generate:sqlite"
  },
  "dependencies": {
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1"
  }
}
